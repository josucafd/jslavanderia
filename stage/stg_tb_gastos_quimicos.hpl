  <transform>
    <name>tb_gastos_quimicos</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>DB_LOGOSYSTEM</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>WITH Aggregated AS (
    SELECT 
        DOCTO,
        CLIFOR,
        SUM(VALOROPERACAO) AS valor_total
    FROM 
        TB_FIDOCTO 
    WHERE 
        ATIVO = 'A' 
        AND CONTADEBITO = 102
    GROUP BY 
        DOCTO,
        CLIFOR
)
SELECT 
    tf.DOCTO,
    tf.CLIFOR,
    tf.DATAENTRADA,
    tf.DATAEMISSAO,
    tf.CENTROCUSTO,
    tf.CONTADEBITO,
    ag.valor_total
FROM 
    TB_FIDOCTO tf
JOIN Aggregated ag ON tf.DOCTO = ag.DOCTO AND tf.CLIFOR = ag.CLIFOR
WHERE 
    tf.ATIVO = 'A' 
    AND tf.CONTADEBITO = 102
GROUP BY
    tf.DOCTO,
    tf.CLIFOR,
    tf.DATAENTRADA,
    tf.DATAEMISSAO,
    tf.CENTROCUSTO,
    tf.CONTADEBITO,
    ag.valor_total
 ORDER BY 
 tf.DATAENTRADA DESC </sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>720</xloc>
      <yloc>256</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
