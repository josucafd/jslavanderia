    <set_params>N</set_params>
    <single_statement>N</single_statement>
    <sql>UPDATE programacoes prog
SET negociacao_fk = (
    SELECT MAX(n.id)
    FROM negociacoes n
    WHERE n.op_cliente = prog.op_cliente
)
WHERE EXISTS (
    SELECT 1
    FROM negociacoes n
    WHERE n.op_cliente = prog.op_cliente
);</sql>
