  <transform>
    <name>tb_ordem_producao</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>DB_LOGOSYSTEM</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT 
    OD.DATAEMISSAO AS data_entrada,
    od.PRAZOENTREGA AS data_entrega,
    OD.NUMEROOF AS op_interna,
    OD.PEDIDOVENDA AS op_cliente,
    OD.STATUS,
    CL.FANTASIA AS CLIENTE,
    PED.QTOP AS quantidade,
    PED.REFERENCIA,
    PED.NOMEPRODUTO AS produto ,
    PRO.DESCRICAO AS RECEITA, 
    tt.DESCRICAO AS TIPO_OP
FROM TB_ORDEMPRODUCAO OD
JOIN TB_CLIFOR CL ON OD.CLIFOR = CL.CLIFOR
JOIN TB_ORDEMPEDIDO PED ON OD.NUMEROOF = PED.NUMEROOF
JOIN TB_PROCESSOSNMRECEITA PRO ON PED.LAVPROCESSO = PRO.PROCESSO
JOIN TB_TIPOOP tt ON tt.TIPO = OD.TIPOOP
WHERE OD.EMPRESA = 1 
  AND OD.FILIAL = 1 
  AND OD.STATUS != 'C'
  AND PED.EMPRESA = 1 
  AND PED.FILIAL = 1
  AND PRO.RECEITA = PED.LAVRECEITAPROC 
  AND OD.DATAEMISSAO > '01/01/2024'</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>144</xloc>
      <yloc>128</yloc>
    </GUI>
  </transform>
